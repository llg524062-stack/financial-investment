# Server
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://financial-investment-one.vercel.app

# Database (SQLite default; use PostgreSQL in production)
DATABASE_URL=sqlite:///./data/finance.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/finance

# Watchlist (comma-separated)
WATCHLIST=NVDA,MSFT,AAPL,TSLA,600519,000300

# Optional API keys
FRED_API_KEY=
FINNHUB_API_KEY=
TUSHARE_TOKEN=

# Optional local LLM (Ollama) for narrative insights
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
ENABLE_LLM=false

# Sync schedule (cron: minute hour)
SYNC_CRON_HOUR=18
SYNC_CRON_MINUTE=30
RUN_SYNC_ON_STARTUP=true
